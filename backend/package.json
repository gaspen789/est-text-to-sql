{
  "name": "keelemudeli-haldur-backend",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "main": "server.js",
  "scripts": {
    "start": "node ../dist/backend/server.cjs",
    "dev": "tsx watch server.ts",
    "mock": "tsx mock-server.ts",
    "build": "esbuild server.ts --bundle --platform=node --format=cjs --outfile=../dist/backend/server.cjs --packages=external",
    "build:standalone": "esbuild server.ts --bundle --platform=node --format=cjs --outfile=../dist/backend/server.cjs",
    "cron:sync-db-resources": "tsx scripts/sync-db-resources.ts",
    "lint": "cd .. && eslint backend"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/google": "^3.0.55",
    "@ai-sdk/openai": "^3.0.49",
    "ai": "^6.0.143",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "mysql2": "^3.14.3",
    "pg": "^8.16.3",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "oracledb": "^6.9.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.6",
    "esbuild": "^0.27.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3"
  }
}
